# Live trading must be explicitly enabled
ENABLE_LIVE_TRADING=false
EMERGENCY_KILL=false

# Robinhood credentials for crypto trading
ROBINHOOD_USERNAME=you@example.com
ROBINHOOD_PASSWORD=your-password

# Watchlist symbols
WATCHLIST=BTC-USD,ETH-USD,SOL-USD,DOGE-USD
SUPPORTED_SYMBOLS=BTC-USD,ETH-USD,SOL-USD,DOGE-USD

# Strategy and risk settings
MARKET_DATA_PROVIDER=auto
ENABLED_STRATEGIES=momentum_breakout
CONFIDENCE_THRESHOLD=70.0
MAX_RISK_PCT=0.01
MAX_POSITION_PCT=0.25
DAILY_LOSS_LIMIT_PCT=0.05
STOP_TRADING_ON_LOSS=true

# Alerts
EMAIL_SMTP_SERVER=smtp.example.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=you@example.com
EMAIL_SMTP_PASSWORD=your-email-password
ALERT_RECIPIENTS=alerts@example.com

# Optional local paths
LOG_PATH=logs/trading.log
DATABASE_PATH=data/trading.db
